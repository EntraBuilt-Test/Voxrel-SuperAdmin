{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "samhita-superadmin",
  "account_id": "01c9697d844727ef4ba702eff67455a3",
  "compatibility_date": "2026-01-27",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "NEXT_PUBLIC_API_URL": "https://samhita-backend-tlpg.onrender.com"
  }
}
